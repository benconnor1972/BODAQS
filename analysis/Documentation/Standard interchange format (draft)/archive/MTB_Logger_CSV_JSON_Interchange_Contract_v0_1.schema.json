{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/mtb_logger_csv_json_interchange_contract_v0_1.schema.json",
  "title": "MTB Logger CSV + JSON Interchange Contract v0.1",
  "description": "Permissive structural schema for the JSON sidecar. Cross-file validation against the CSV is defined in the Markdown contract.",
  "type": "object",
  "required": [
    "contract",
    "streams",
    "columns"
  ],
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "data_file": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "delimiter": {
          "type": "string",
          "minLength": 1
        },
        "header": {
          "type": "boolean"
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "session_id": {
          "type": "string"
        },
        "started_at_local": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "streams": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/stream"
      }
    },
    "sensors": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sensor"
      }
    },
    "transforms": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/transform"
      }
    },
    "columns": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/column"
      }
    },
    "qc": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "warnings": {
          "type": "array"
        },
        "time": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "monotonic": {
              "type": "boolean"
            },
            "repaired": {
              "type": "boolean"
            }
          }
        },
        "firmware_stats": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "logger_family": {
          "type": "string"
        },
        "firmware_version": {
          "type": "string"
        },
        "metadata_generated_at": {
          "type": "string"
        },
        "generator": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "stream": {
      "type": "object",
      "required": [
        "type",
        "time_col",
        "time_unit"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "uniform",
            "intermittent"
          ]
        },
        "time_col": {
          "type": "string",
          "minLength": 1
        },
        "time_unit": {
          "type": "string",
          "const": "s"
        },
        "sample_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "jitter_frac": {
          "type": "number",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "sensor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "raw_unit": {
          "type": "string"
        },
        "calibration": {
          "$ref": "#/$defs/calibration"
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "input_unit": {
          "type": "string"
        },
        "output_unit": {
          "type": "string"
        },
        "installed_zero_count": {
          "type": "number"
        },
        "sensor_zero_count": {
          "type": "number"
        },
        "sensor_full_count": {
          "type": "number"
        },
        "sensor_full_travel": {
          "type": "number"
        },
        "invert": {
          "type": "boolean"
        }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "input_unit": {
          "type": "string"
        },
        "output_unit": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "interpolation": {
          "type": "string"
        },
        "extrapolation": {
          "type": "string"
        },
        "lut": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/lut_point"
          }
        }
      }
    },
    "lut_point": {
      "type": "object",
      "required": [
        "input",
        "output"
      ],
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "number"
        },
        "output": {
          "type": "number"
        }
      }
    },
    "column": {
      "oneOf": [
        {
          "$ref": "#/$defs/time_column"
        },
        {
          "$ref": "#/$defs/signal_column"
        },
        {
          "$ref": "#/$defs/generic_column"
        }
      ]
    },
    "base_column": {
      "type": "object",
      "required": [
        "class",
        "dtype"
      ],
      "additionalProperties": true,
      "properties": {
        "class": {
          "type": "string",
          "enum": [
            "time",
            "signal",
            "index",
            "event_flag",
            "qc_flag"
          ]
        },
        "dtype": {
          "type": "string",
          "minLength": 1
        },
        "stream": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "sensor": {
          "type": "string"
        },
        "quantity": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "source_columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "calibration_ref": {
          "type": "string"
        },
        "transform_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "time_column": {
      "allOf": [
        {
          "$ref": "#/$defs/base_column"
        },
        {
          "type": "object",
          "required": [
            "class",
            "dtype",
            "stream",
            "unit"
          ],
          "properties": {
            "class": {
              "const": "time"
            },
            "unit": {
              "const": "s"
            }
          }
        }
      ]
    },
    "signal_column": {
      "allOf": [
        {
          "$ref": "#/$defs/base_column"
        },
        {
          "type": "object",
          "required": [
            "class",
            "dtype",
            "stream",
            "quantity",
            "unit"
          ],
          "properties": {
            "class": {
              "const": "signal"
            }
          }
        }
      ]
    },
    "generic_column": {
      "allOf": [
        {
          "$ref": "#/$defs/base_column"
        },
        {
          "type": "object",
          "properties": {
            "class": {
              "enum": [
                "index",
                "event_flag",
                "qc_flag"
              ]
            }
          }
        }
      ]
    }
  }
}
