{
  "schema": "bodaqs.session_notes.template",
  "version": 1,
  "template_id": "suspension_setup",
  "template_version": "1.0",
  "title": "Suspension setup",
  "description": "Starter template for recording suspension setup and test-session context.",
  "allow_custom_fields": true,
  "custom_field_section": "Custom",
  "fields": [
    {
      "field_id": "setup_variant",
      "label": "Setup variant",
      "field_type": "enum",
      "section": "Overview",
      "default": "baseline",
      "enum_options": ["baseline", "wet", "dry", "park", "test"],
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "front_air_pressure_psi",
      "label": "Front air pressure",
      "field_type": "float",
      "section": "Front",
      "unit": "psi",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "rear_air_pressure_psi",
      "label": "Rear air pressure",
      "field_type": "float",
      "section": "Rear",
      "unit": "psi",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "front_tokens",
      "label": "Front tokens",
      "field_type": "int",
      "section": "Front",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "rear_tokens",
      "label": "Rear tokens",
      "field_type": "int",
      "section": "Rear",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "front_rebound_clicks",
      "label": "Front rebound clicks",
      "field_type": "int",
      "section": "Front",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "rear_rebound_clicks",
      "label": "Rear rebound clicks",
      "field_type": "int",
      "section": "Rear",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "front_sag_pct",
      "label": "Front sag",
      "field_type": "float",
      "section": "Front",
      "unit": "%",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "rear_sag_pct",
      "label": "Rear sag",
      "field_type": "float",
      "section": "Rear",
      "unit": "%",
      "project_to_catalog": true,
      "sortable": true,
      "filterable": true
    },
    {
      "field_id": "test_conditions",
      "label": "Test conditions",
      "field_type": "text",
      "section": "Overview",
      "project_to_catalog": false,
      "sortable": false,
      "filterable": false
    }
  ]
}
